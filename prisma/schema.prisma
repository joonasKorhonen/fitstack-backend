generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  password      String
  avatarUrl     String?
  workouts      Workout[]
  meals         Meal[]
  movements     Movement[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  token       String
  tokenFamily String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Workout {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @default(now())
  exercise  String
  reps      Int
  weight    Float?
  notes     String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
  sets      WorkoutSet[]
}

model WorkoutSet {
  id          Int       @id @default(autoincrement())
  exercise    String?
  movementId  Int?
  movement    Movement? @relation(fields: [movementId], references: [id], onDelete: SetNull)
  reps        Int
  weight      Float?
  intensity   Int?
  notes       String?
  workoutId   Int
  workout     Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([movementId])
}

model Movement {
  id        Int          @id @default(autoincrement())
  userId    Int
  name      String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets      WorkoutSet[]
  createdAt DateTime     @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model Meal {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @default(now())
  title     String
  calories  Int
  protein   Int?
  carbs     Int?
  fat       Int?
  notes     String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
